    "import requests\n",
    "\n",
    "# Ollama setup - make sure Ollama is running locally\n",
    "# Run: ollama serve (if not already running as a service)\n",
    "# Pull model: ollama pull llama3.1:8b\n",
    "\n",
    "OLLAMA_BASE_URL = \"http://localhost:11434\"  # Default Ollama URL\n",
    "MODEL_ID = \"llama3.1:8b\"  # Ollama model name (change to your installed model)\n",
    "MODEL_TAG = MODEL_ID.replace(\":\", \"_\").replace(\".\", \"_\").replace(\"-\", \"_\")\n",
    "\n",
    "def call_ollama(prompt: str, model: str = MODEL_ID, max_tokens: int = 48) -> str:\n",
    "    \"\"\"Call Ollama API to generate text.\"\"\"\n",
    "    url = f\"{OLLAMA_BASE_URL}/api/generate\"\n",
    "    payload = {\n",
    "        \"model\": model,\n",
    "        \"prompt\": prompt,\n",
    "        \"stream\": False,\n",
    "        \"options\": {\n",
    "            \"num_predict\": max_tokens,\n",
    "            \"temperature\": 0.0,\n",
    "        }\n",
    "    }\n",
    "    try:\n",
    "        response = requests.post(url, json=payload, timeout=120)\n",
    "        response.raise_for_status()\n",
    "        return response.json()[\"response\"]\n",
    "    except Exception as e:\n",
    "        print(f\"Error calling Ollama: {e}\")\n",
    "        return \"\"\n",
    "\n",
    "print(f\"Using Ollama model: {MODEL_ID}\")\n",
    "print(f\"Ollama URL: {OLLAMA_BASE_URL}\")"
   ]
  },
